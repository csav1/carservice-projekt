<Window x:Class="carservice_projekt.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Dashboard"
       MinHeight="550" MinWidth="850"
        ResizeMode="CanResize"
        Background="#2A2A2A"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="30" VerticalAlignment="Center">

        <TextBox Text="Dashboard-View"
                 FontSize="35"
                 Margin="0,0,0,60"
                 HorizontalAlignment="Center"
                 Foreground="White"
                 Background="DarkSlateBlue"
                 BorderThickness="0"/>

        <Button Content="Fahrzeuginformationen"
                ToolTip="Öffnet die Fahrzeugverwaltung"
                FontSize="25"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Height="55"
                Width="360"
                Background="SlateGray"
                Foreground="White"/>

        <Button Content="Bearbeitung von Wartungen"
                ToolTip="Hier können Wartungen erstellt und bearbeitet werden"
                FontSize="25"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Height="55"
                Width="360"
                Background="SteelBlue"
                Foreground="White"/>

        <Button Content="Liste der Wartungen"
                ToolTip="Zeigt alle gespeicherten Wartungen an"
                FontSize="25"
                Margin="0,0,0,30"
                HorizontalAlignment="Center"
                Height="55"
                Width="360"
                Background="DarkSlateGray"
                Foreground="White"/>

        <GroupBox Header="Fahrzeuge"
                  Margin="20"
                  Foreground="White">

            <DataGrid x:Name="dgFahrzeuge"
                      AutoGenerateColumns="False"
                      Height="150"
                      ToolTip="Übersicht der gespeicherten Fahrzeuge">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Marke"
                                        Binding="{Binding Marke}"
                                        Width="*" />

                    <DataGridTextColumn Header="Modell"
                                        Binding="{Binding Modell}"
                                        Width="*" />

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

        <Button Content="Informationen >>"
                Click="Button_Click_1"
                ToolTip="Wechselt zur Fahrzeugerfassung"
                FontSize="16"
                Width="200"
                Height="40"
                Background="Silver"
                HorizontalAlignment="Right"/>

    </StackPanel>

</Window>